# MongoDB Atlas - ضع رابط الاتصال من لوحة Atlas
MONGODB_URI=mongodb://USERNAME:PASSWORD@your-cluster.mongodb.net/?authSource=admin

# Brevo (Sendinblue) - من لوحة Brevo: SMTP & API
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your@email.com

# JWT - مفتاح سري قوي للإنتاج
JWT_SECRET=your-jwt-secret

NODE_ENV=development
